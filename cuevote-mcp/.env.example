# CueVote MCP server configuration
# Copy to .env (or set these in your MCP client config) and fill in.

# --- Phase 1a: read-only tools (SQLite) ---
# Path to the cuevote-server SQLite file. Relative paths resolve against the
# cuevote-mcp package root. Default points at a sibling cuevote-server checkout.
CUEVOTE_DB_PATH=../cuevote-server/cuevote.db

# --- Phase 1b: live ops / moderation (server admin API) ---
# Must match ADMIN_TOKEN set on the cuevote-server. Leave empty to disable the
# live-ops tools. The admin API is expected to listen on localhost only.
CUEVOTE_ADMIN_URL=http://127.0.0.1:8081
CUEVOTE_ADMIN_TOKEN=

# --- Phase 2: AI-DJ / guest control (WebSocket bridge) ---
# A CueVote *session token* (obtained from the web app after Google login),
# NOT a Google OAuth token. Leave empty to disable the DJ tools.
CUEVOTE_WS_URL=wss://cuevote.com
CUEVOTE_WS_ORIGIN=https://cuevote.com
CUEVOTE_SESSION_TOKEN=

# Audit log for write actions (relative paths resolve against the package root).
CUEVOTE_AUDIT_LOG=mcp-audit.log

# --- Remote DJ MCP (public, OAuth) — the HTTP entrypoint (dist/http.js) ---
# Binds localhost; nginx + Cloudflare sit in front.
CUEVOTE_HTTP_HOST=127.0.0.1
CUEVOTE_HTTP_PORT=8082
# Public issuer/base URL clients reach (used as the OAuth issuer + resource id).
CUEVOTE_PUBLIC_URL=https://mcp.cuevote.com
# Mint WS sessions for authenticated users via the server's internal API.
# CUEVOTE_INTERNAL_URL defaults to the admin API; CUEVOTE_MINT_SECRET must match
# the server's MCP_SESSION_SECRET.
CUEVOTE_INTERNAL_URL=http://127.0.0.1:8081
CUEVOTE_MINT_SECRET=
# Per-user suggestion rate limit (YouTube quota guardrail).
CUEVOTE_SUGGEST_PER_MIN=10
# OAuth identity:
#   PROD: the web consent/login page authorize redirects to, + the shared secret
#   the web app uses to finalize a login via POST /oauth/finalize.
CUEVOTE_OAUTH_CONSENT_URL=https://cuevote.com/connect-ai
CUEVOTE_OAUTH_FINALIZE_SECRET=
#   DEV/TEST ONLY: auto-approve this CueVote user id without Google. Leave EMPTY
#   in production — it bypasses login.
# CUEVOTE_OAUTH_DEV_USER=
